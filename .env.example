# ============================================================
# CareerCraft AI — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# Supabase — https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key

# Paddle — https://vendors.paddle.com/authentication
# Use sandbox for testing: https://sandbox-vendors.paddle.com
VITE_PADDLE_CLIENT_TOKEN=your-client-token
PADDLE_API_KEY=your-api-key
PADDLE_WEBHOOK_SECRET=your-webhook-secret

# Paddle Price IDs (create in Paddle > Catalog > Products)
VITE_PADDLE_PRO_PRICE_ID=pri_your-pro-price-id
VITE_PADDLE_PREMIUM_PRICE_ID=pri_your-premium-price-id

# App
VITE_APP_URL=https://javetech.online/careercraft
ADMIN_SECRET=choose-a-random-secret-here
PORT=3002
